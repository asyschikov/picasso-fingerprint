{
  "name": "picasso-fingerprint",
  "version": "1.0.0",
  "description": "Picasso: Lightweight device class fingerprinting for web clients using HTML5 canvas rendering differences",
  "main": "index.js",
  "browser": "index.js",
  "files": [
    "index.js"
  ],
  "scripts": {
    "build": "esbuild demo/client.js --bundle --outfile=public/bundle.js",
    "start": "npm run build && node server.js",
